{
  "name": "panel_autocalc_demo",
  "version": "1.0.0",
  "description": "My Remotion video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.cjs",
  "dependencies": {
    "@remotion/cli": "4.0.441",
    "@remotion/media": "^4.0.441",
    "@remotion/player": "4.0.441",
    "@remotion/tailwind-v4": "4.0.441",
    "@vitejs/plugin-react": "4.3.3",
    "fflate": "^0.8.2",
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.59.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.441",
    "tailwindcss": "4.0.0",
    "vite": "5.4.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.441",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/web": "0.0.166",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "init-composition": "node scripts/init-composition.mjs",
    "postinstall": "node scripts/init-composition.mjs",
    "dev": "node scripts/init-composition.mjs && remotion studio",
    "editor": "node scripts/init-composition.mjs && vite",
    "electron-dev": "node scripts/init-composition.mjs && electron .",
    "install-pw-browsers": "node scripts/install-playwright-browsers.mjs",
    "build": "node scripts/init-composition.mjs && remotion bundle",
    "editor-build": "vite build",
    "dist": "vite build && electron-builder --mac --arm64",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ],
  "build": {
    "appId": "com.dabinky.app",
    "productName": "Dabinky",
    "asar": false,
    "extraResources": [
      {
        "from": "pw-browsers",
        "to": "pw-browsers"
      }
    ],
    "files": [
      "electron/**/*",
      "vite.config.ts",
      "editor/dist/**/*",
      "editor/chunk-render.html",
      "editor/index.html",
      "src/**/*",
      "scripts/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.video",
      "target": {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      },
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "artifactName": "${productName}.${ext}"
    }
  }
}
